{
  "kind": "collectionType",
  "collectionName": "admins",
  "info": {
    "singularName": "admin",
    "pluralName": "admins",
    "displayName": "admins"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string",
      "minLength": 2,
      "maxLength": 30,
      "required": true,
      "unique": true
    },
    "posts": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::post.post",
      "mappedBy": "admin"
    },
    "avatar": {
      "type": "integer",
      "required": true
    },
    "password": {
      "type": "string",
      "minLength": 5,
      "required": true
    },
    "following": {
      "type": "json"
    },
    "savedPosts": {
      "type": "json"
    },
    "career": {
      "type": "string",
      "maxLength": 50
    },
    "placeOfBirth": {
      "type": "string",
      "maxLength": 50
    },
    "dateOfBirth": {
      "type": "date"
    }
  }
}
