{
  "kind": "collectionType",
  "collectionName": "posts",
  "info": {
    "singularName": "post",
    "pluralName": "posts",
    "displayName": "posts"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "descriptions": {
      "type": "text",
      "minLength": 10,
      "required": true
    },
    "time": {
      "type": "string",
      "default": "00:00",
      "required": true
    },
    "date": {
      "type": "string",
      "default": "00.00.00",
      "required": true
    },
    "admin": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::admin.admin",
      "inversedBy": "posts"
    },
    "image": {
      "type": "media",
      "multiple": true,
      "required": true,
      "allowedTypes": [
        "images",
        "files"
      ]
    }
  }
}
